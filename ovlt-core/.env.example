# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ovlt:ovlt@localhost:5432/ovlt
# Production: include sslmode=require
# DATABASE_URL=postgresql://ovlt:PASSWORD@host:5432/ovlt?sslmode=require

# ─── Secrets (generate each with: openssl rand -base64 48) ───────────────────
JWT_SECRET=
MASTER_ENCRYPTION_KEY=
# Must differ from MASTER_ENCRYPTION_KEY
TENANT_WRAP_KEY=

# ─── Token TTLs ───────────────────────────────────────────────────────────────
JWT_EXPIRATION_MINUTES=15
REFRESH_TOKEN_EXPIRATION_DAYS=30

# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
ENVIRONMENT=development
# production | development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Use * for development only. Production requires explicit origins.
CORS_ALLOWED_ORIGINS=*
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# ─── Admin API ────────────────────────────────────────────────────────────────
# Static key required in X-OVLT-Admin-Key header for /tenants endpoints.
# If not set, /tenants endpoints return 404.
# Production: use a strong random value (openssl rand -base64 32)
OVLT_ADMIN_KEY=

# ─── Bootstrap ────────────────────────────────────────────────────────────────
# On first startup (zero tenants), OVLT automatically creates the master tenant
# and an admin user — same pattern as Keycloak's KEYCLOAK_ADMIN vars.
# Safe to leave in docker-compose for dev. Remove after first prod deploy if desired.
OVLT_BOOTSTRAP_TENANT_SLUG=master
OVLT_BOOTSTRAP_ADMIN_EMAIL=
OVLT_BOOTSTRAP_ADMIN_PASSWORD=

# ─── OAuth Providers (optional) ───────────────────────────────────────────────
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google/callback

#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=
#GITHUB_REDIRECT_URL=http://localhost:3000/auth/github/callback
