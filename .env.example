# Copy this file to .env and adjust values before running locally.
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ovtl:ovtl@localhost:5432/ovtl

# ── Security (change all of these — minimum 32 chars) ─────────────────────────
JWT_SECRET=dev-jwt-secret-change-me-min-32-chars
MASTER_ENCRYPTION_KEY=dev-master-enc-key-change-me-32c
TENANT_WRAP_KEY=dev-tenant-wrap-key-change-me-32c!

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=*

# ── OIDC ──────────────────────────────────────────────────────────────────────
OVTL_ISSUER=http://localhost:3000
# RSA_PRIVATE_KEY=<base64-encoded PKCS8 PEM>
# Leave unset in dev — an ephemeral key is generated on startup.
# Generate for production:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 | \
#   openssl pkcs8 -topk8 -nocrypt | base64 | tr -d '\n'

# ── Admin ─────────────────────────────────────────────────────────────────────
OVTL_ADMIN_KEY=dev-admin-key

# ── Bootstrap (runs once on first startup if no tenants exist) ────────────────
OVTL_BOOTSTRAP_TENANT_SLUG=master
OVTL_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
OVTL_BOOTSTRAP_ADMIN_PASSWORD=Admin1234!
