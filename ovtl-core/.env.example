DATABASE_URL=postgresql://ovtl:ovtl@localhost:5432/ovtl

# Generate: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRATION_MINUTES=15

REFRESH_TOKEN_EXPIRATION_DAYS=30

# Generate: openssl rand -base64 64
MASTER_ENCRYPTION_KEY=

# Must differ from MASTER_ENCRYPTION_KEY. Generate: openssl rand -base64 64
TENANT_WRAP_KEY=

SERVER_HOST=0.0.0.0
SERVER_PORT=3000
ENVIRONMENT=development

# Use * for development. Must be explicit in production (e.g. https://app.example.com)
CORS_ALLOWED_ORIGINS=*

# OAuth2 providers (optional)
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google/callback

#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=
#GITHUB_REDIRECT_URL=http://localhost:3000/auth/github/callback
